# SenseSearch Backend Environment Configuration
# Copy this file to .env and update with your values

# ===================================
# Application Configuration
# ===================================
APP_NAME=sensesearch-backend
APP_VERSION=0.1.0

# Environment: development | staging | production
ENVIRONMENT=development

# ===================================
# Database Configuration
# ===================================
# Development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./sensesearch.db

# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://sensesearch:sensesearch_password@localhost:5432/sensesearch

# Docker Compose (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://sensesearch:sensesearch_password@postgres:5432/sensesearch

# ===================================
# Milvus Vector Database Configuration
# ===================================
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=sensesearch

# Docker Compose
# MILVUS_HOST=milvus
# MILVUS_PORT=19530
# MILVUS_COLLECTION_NAME=sensesearch

# ===================================
# API Configuration
# ===================================
API_PREFIX=/api/v1

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:80

# Docker Compose
# CORS_ORIGINS=http://nginx,http://localhost

# ===================================
# Security Configuration
# ===================================
# Generate a secure random key for production
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32

# Access token expiration (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Refresh token expiration (in minutes)
REFRESH_TOKEN_EXPIRE_MINUTES=604800

# ===================================
# File Upload Configuration
# ===================================
# Maximum file size in bytes (default 100MB)
MAX_FILE_SIZE=104857600

# Upload directory relative to app root
UPLOAD_DIR=uploads

# Allowed image extensions
ALLOWED_IMAGE_EXTENSIONS=png,jpg,jpeg,webp,gif

# Allowed video extensions
ALLOWED_VIDEO_EXTENSIONS=mp4,webm,mov

# ===================================
# Embedding API Configuration
# ===================================
# URL for embedding service (text/image/video vectors)
EMBEDDING_API_URL=https://api.example.com/v1/embed

# API key for embedding service
# EMBEDDING_API_KEY=your-embedding-api-key

# ===================================
# LLM Configuration (for AI conversations)
# ===================================
# LLM API URL (default: Alibaba DashScope / Qwen)
LLM_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/text-generation/generation

# LLM API Key
# LLM_API_KEY=your-llm-api-key

# LLM Model Name
LLM_MODEL=qwen-turbo

# LLM Temperature (0.0-1.0, higher = more creative)
LLM_TEMPERATURE=0.7

# LLM Max Tokens
LLM_MAX_TOKENS=2000

# Alternative: OpenAI
# LLM_API_URL=https://api.openai.com/v1/chat/completions
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# ===================================
# Worker Configuration (for async tasks)
# ===================================
# Celery broker URL (Redis)
# CELERY_BROKER_URL=redis://localhost:6379/0

# Result backend
# CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ===================================
# Logging Configuration
# ===================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format: json | text
LOG_FORMAT=json

# Sentry DSN (for error tracking)
# SENTRY_DSN=https://...
