# 应用配置
APP_NAME=sensesearch-backend
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# 数据库配置
# 开发环境使用 SQLite
DATABASE_URL=sqlite+aiosqlite:///./sensesearch.db
# 生产环境使用 PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sensesearch

# Milvus 配置
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=sensesearch

# API 配置
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# 安全配置
SECRET_KEY=your-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 文件上传配置
MAX_FILE_SIZE=104857600
UPLOAD_DIR=uploads
